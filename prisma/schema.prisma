generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Role {
  USER
  ADMIN
}

enum OtpType {
  VERIFICATION
  PASSWORD_RESET
  LOGIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// --- Models ---

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(USER)
  isVerified   Boolean  @default(false) @map("is_verified")
  isBanned     Boolean  @default(false) @map("is_banned")
  createdAt    DateTime @default(now()) @map("created_at")

  orders        Order[]
  refreshTokens RefreshToken[]
  reviews       Review[]
  addresses     Address[]
  wishlisted    Product[]      @relation("UserWishlist")

  @@map("users")
}

model Address {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  label      String   @default("Home") @db.VarChar(50)
  street     String   @db.Text
  city       String   @db.VarChar(100)
  state      String   @db.VarChar(100)
  postalCode String   @map("postal_code") @db.VarChar(20)
  country    String   @db.VarChar(100)
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  otp       String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  type      OtpType
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_codes")
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(255)
  slug     String     @unique @db.VarChar(255)
  imageUrl String?    @map("image_url") @db.VarChar(255)
  publicId String?    @map("public_id") @db.VarChar(255)
  products Product[]
  parentId Int?       @map("parent_id")
  parent   Category?  @relation("CategoryToSub", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToSub")

  @@map("categories")
}

model Product {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)
  stock         Int      @default(0)
  categoryId    Int      @map("category_id")
  imageUrl      String?  @map("image_url") @db.VarChar(255)
  publicId      String?  @map("public_id") @db.VarChar(255)

  tags Tag[] @relation("ProductTags")

  isFeatured     Boolean @default(false) @map("is_featured")
  isDealOfTheDay Boolean @default(false) @map("is_deal_of_the_day")
  isActive       Boolean @default(true) @map("is_active")

  ratingAvg   Decimal @default(0) @map("rating_avg") @db.Decimal(3, 2)
  reviewCount Int     @default(0) @map("review_count")

  createdAt DateTime @default(now()) @map("created_at")

  category     Category         @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  variants     ProductVariant[]
  orderItems   OrderItem[]
  reviews      Review[]
  wishlistedBy User[]           @relation("UserWishlist")

  @@map("products")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  rating    Int      @default(5)
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("reviews")
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int    @map("product_id")
  imageUrl  String @map("image_url") @db.VarChar(255)
  publicId  String @map("public_id") @db.VarChar(255)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id              Int     @id @default(autoincrement())
  productId       Int     @map("product_id")
  variantName     String  @map("variant_name") @db.VarChar(50)
  additionalPrice Decimal @default(0) @map("additional_price") @db.Decimal(10, 2)
  stock           Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("product_variants")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int         @map("user_id")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentId       String?     @map("payment_id") @db.VarChar(255)
  shippingAddress String?     @map("shipping_address") @db.Text
  phoneNumber     String?     @map("phone_number") @db.VarChar(20)
  couponCode      String?     @map("coupon_code") @db.VarChar(50)
  discountApplied Decimal     @default(0) @map("discount_applied") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")

  user   User        @relation(fields: [userId], references: [id])
  items  OrderItem[]
  coupon Coupon?     @relation(fields: [couponCode], references: [code])

  @@map("orders")
}

model OrderItem {
  id               Int     @id @default(autoincrement())
  orderId          Int     @map("order_id")
  productId        Int     @map("product_id")
  productVariantId Int?    @map("product_variant_id")
  quantity         Int
  price            Decimal @db.Decimal(10, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@map("order_items")
}

model Coupon {
  id            Int          @id @default(autoincrement())
  code          String       @unique @db.VarChar(50)
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  expiresAt     DateTime?    @map("expires_at")
  usageLimit    Int?         @map("usage_limit")
  usedCount     Int          @default(0) @map("used_count")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")

  orders Order[]

  @@map("coupons")
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[] @relation("ProductTags")

  @@map("tags")
}
